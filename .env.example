# At least one LLM provider required. NVIDIA recommended (free endpoint).
# Priority: NVIDIA > Gemini > Ollama (auto-detected)

NVIDIA_API_KEY=your_nvidia_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OLLAMA_BASE_URL=http://localhost:11434

# Optional overrides
# LLM_PROVIDER=auto            # auto | nvidia | gemini | ollama
# CORPUS_KILL_SWITCH=false      # Emergency kill-switch for corpus operations
# RETRIEVAL_CONTRACTS_ENABLED=true
